// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "use_smartcase_search": true,
  "diff_view_style": "unified",
  "file_finder": {
    "file_icons": true
  },
  "project_panel": {
    "dock": "right"
  },
  "cli_default_open_behavior": "existing_window",
  "show_signature_help_after_edits": false,
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "agent_ui_font_size": 16,
  "buffer_font_family": "JetBrainsMono Nerd Font Mono",
  "ui_font_family": "JetBrainsMono Nerd Font Propo",
  "show_whitespaces": "boundary",
  "colorize_brackets": true,
  "tab_bar": {
    // "show": false,
  },
  "toolbar": {
    // "breadcrumbs": false,
    // "agent_review": false,
    "quick_actions": false,
  },
  "scrollbar": {
    "axes": {
      "horizontal": false,
    },
  },
  "show_edit_predictions": false,
  "agent": {
    "default_profile": "write",
    "show_turn_stats": true,
    "use_modifier_to_send": true,
    "tool_permissions": {
      "default": "allow",
      "tools": {}
    },
    "default_model": {
      "effort": "high",
      "provider": "deepseek",
      "model": "deepseek-v4-pro",
      "enable_thinking": true
    },
    "favorite_models": [],
    "model_parameters": [],
    "enable_feedback": false,
    "commit_message_model": {
      "provider": "deepseek",
      "model": "deepseek-v4-flash",
      "enable_thinking": false,
      "speed": "fast"
    }
  },
  "edit_predictions": {
    "mode": "eager",
    "provider": "none",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "base_keymap": "VSCode",
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Bearded Icon Theme",
  },
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Kanagawa",
  },
  "prettier": {
    "allowed": false,
  },
  "when_closing_with_no_tabs": "keep_window_open",
  "terminal": {
    "cursor_shape": "bar",
    "blinking": "on",
    "detect_venv": "off",
  },
  // Languages
  "languages": {
    "Python": {
      "show_edit_predictions": true,
      "language_servers": [
        "pyrefly",
        "ruff",
        "!basedpyright"
      ],
      "format_on_save": "on",
      "formatter": [
        {
          "code_action": "source.organizeImports.ruff",
        },
        {
          "code_action": "source.fixAll.ruff",
        },
        {
          "language_server": {
            "name": "ruff",
          },
        },
      ],
    },
    "Go": {
      "language_servers": [
        "gopls",
        "golangci-lint"
      ],
    },
    "YAML": {
      "tab_size": 2
    }
  },
  "file_types": {
    "Dockerfile": [
      "Dockerfile.*"
    ],
  },
  "lsp": {
    "ruff": {
      "initialization_options": {
        "settings": {
          "organizeImports": true,
          "lineLength": 80,
          "fixAll": true,
        },
      },
    },
    "pyrefly": {
      "settings": {
        "python": {
          "pythonPath": ".venv/bin/python3",
        },
        "pyrefly": {
          "project_includes": [
            "**/*.py",
            "*.py"
          ],
          "project_excludes": [
            "**/.[!/.]*",
            "**/*venv/**"
          ],
          "search_path": [
            "."
          ],
          "ignore_errors_in_generated_code": true,
        },
      },
    },
    "golangci-lint": {
      "initialization_options": {
        "command": [
          "golangci-lint",
          "run",
          "--output.json.path",
          "stdout",
          "--show-stats=false",
          "--output.text.path="
        ]
      }
    }
  },
}
